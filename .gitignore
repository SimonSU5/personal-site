# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# sensitive data files
data/github-settings.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/

# data/ 与 assets/ 已纳入版本管理（内容数据 + 同步资源）。
# 仅 data/github-settings.json 含凭证，保持忽略（见上方 sensitive data files）。

# docs/ 本地维护（FRONTEND_GUIDE.md 不入库，随本地更新）
/docs/
